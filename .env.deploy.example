# 对外访问端口
APP_PORT=3000
APP_BIND=127.0.0.1

# 填写已解析到本服务器的域名后，一键脚本会启用 Caddy 自动 HTTPS
DOMAIN=

# 容器内配置，请勿修改 PORT 和 DATA_DIR
PORT=3000
DATA_DIR=/app/data
HOST_DATA_DIR=./data
TRUST_PROXY=true

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 镜像名称，通常无需修改
APP_IMAGE=stumng:local

# 首次部署前必须修改管理员密码
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=系统管理员

# Linux 文件权限映射；deploy.sh 会自动填写
HOST_UID=1000
HOST_GID=1000
